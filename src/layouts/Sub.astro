---
import "../global.css"
const {title} = Astro.props;

import Navigation from "../components/Navigation.astro"
import Footer from "../components/Footer.astro"
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="favicon.svg">
    <title>{title}</title>
  </head>
  <body>
    <Navigation />
    <slot />
    <Footer />
</body>
</html>